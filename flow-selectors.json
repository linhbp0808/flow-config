{
  "version": "1.0.0",
  "updatedAt": "2026-05-08",
  "_comment": "Flow Studio remote selectors. Push commit lên repo → user fetch sau 24h (hoặc bấm Refresh) sẽ nhận update. KHÔNG cần build extension lại.",

  "panel": {
    "qtyRegex": "x[1-4]|[1-4]x",
    "iconKeywords": ["crop_", "aspect_ratio"],
    "modeKeywords": ["Video", "Hình", "Image"]
  },

  "modeTabs": {
    "image": { "texts": ["Hình ảnh", "Image", "Images"], "icons": ["image"] },
    "video": { "texts": ["Video", "Videos"], "icons": ["play_circle", "movie", "videocam"] }
  },

  "tiles": {
    "outputItems": "[data-tile-id]",
    "tileById": "[data-tile-id=\"{tileId}\"]",
    "tileEditLink": "[data-tile-id=\"{tileId}\"] a[href*=\"/edit/\"]",
    "editLinkAny": "a[href*=\"/edit/\"]"
  },

  "skeletons": {
    "containers": "div.bqNkKb, div[class*=\"sc-55ebc859-2\"]"
  },

  "icons": {
    "submitArrow": ["arrow_forward", "send"],
    "addImage": ["add_2", "add"],
    "download": ["download"],
    "modelDropdown": ["arrow_drop_down", "expand_more"],
    "cropAspect": ["crop_landscape", "crop_portrait", "crop_square", "crop_16_9", "crop_9_16"]
  }
}
